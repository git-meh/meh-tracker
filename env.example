# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Settings → API → service_role key (keep secret, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database ─────────────────────────────────────────────────────────────────
# Get from: Supabase → Settings → Database → Connection string (Transaction mode)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# ─── App URL ──────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000
# Production: https://your-deployed-domain.com
NEXT_PUBLIC_APP_URL=

# ─── Job Ingestion API Key ────────────────────────────────────────────────────
# YOU GENERATE THIS YOURSELF — it is just a password you make up.
# It protects the /api/job-sources/ingest endpoint so only your scrapers can push jobs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then put the same value in both .env.local AND when running the scrapers.
JOB_INGESTION_API_KEY=

# ─── Cron Secret ─────────────────────────────────────────────────────────────
# YOU GENERATE THIS YOURSELF — same idea as above.
# Protects /api/cron/scrape so only Vercel (or you) can trigger it.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ─── OpenRouter (Optional — free AI features) ─────────────────────────────────
# Sign up free at https://openrouter.ai — no payment card required.
# Gives access to free AI models for match scoring and cover letter generation.
# If blank, the system uses keyword matching + template cover letters instead (still works).
OPENROUTER_API_KEY=
# Primary free model used for CV tailoring, match reasoning, and application drafts.
# Recommended default as of 2026-04-14:
OPENROUTER_MODEL=
# Optional comma-separated fallbacks. Requests automatically fall through on 404/429/5xx.
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_MAX_RETRIES=
OPENROUTER_RETRY_BASE_DELAY_MS=
OPENROUTER_REQUEST_TIMEOUT_MS=

# ─── Automation / Notifications (Optional — Phase 4+) ────────────────────────
# These are not needed to launch. Leave blank until you build the executor service.
# See docs/BUILD-ROADMAP.md Phase 4 for details.
AUTOMATION_EXECUTOR_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_URL=
